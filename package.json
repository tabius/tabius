{
  "name": "tabius",
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "repository": {},
  "scripts": {
    "clean": "rm -rf dist",
    "full-clean": "find . -depth \\( -name \"node_modules\" -o -name \".next\" -o -name \"dist\" -o -name \".angular\" -o -name \"build\" \\) -type d -exec rm -rf {} +",
    "build": "npm run update-version && ng build",
    "build:ssr-dev-ru": "npm run update-version && ng build -c dev-ru",
    "build:ssr-ru": "npm run clean && npm run update-version && ng build -c ru && npm run inline-css",
    "deploy:ssr-ru": "ssh ram 'bash -lc \"cd work/tabius-ru && git pull && npm install\"' && npm run build:ssr-ru && rsync -avz -e ssh ./dist/ ram:work/tabius-ru/dist && ssh ram 'bash -lc \"pm2 restart tabius-ru nest-ru\"'",
    "start-dist": "node dist/server/server.mjs",
    "start-ng-ssr-ru": "ng serve -c dev-ru --port=12101",
    "start-ng-browser-ru": "npm run update-version && ng serve -c dev-ru-csr --port=12102",
    "backend": "nodemon",
    "fix-site-index": "mv dist/browser/index-org.html dist/browser/index.html",
    "inline-css": "ts-node --project scripts/tsconfig.json scripts/inline-css.ts && npm run ngsw-json",
    "ngsw-json": "node_modules/.bin/ngsw-config dist/browser ngsw-config.json",
    "sitemap": "TS_NODE_PROJECT=scripts/tsconfig.json node -r tsconfig-paths/register -r ts-node/register scripts/generate-sitemap.ts",
    "check-youtube": "TS_NODE_PROJECT=scripts/tsconfig.json node -r tsconfig-paths/register -r ts-node/register scripts/check-youtube-links.ts",
    "find-youtube-replacements": "TS_NODE_PROJECT=scripts/tsconfig.json node -r tsconfig-paths/register -r ts-node/register scripts/find-youtube-replacements.ts",
    "update-deps": "rm package-lock.json && rm -rf node_modules && npm install",
    "update-version": "node scripts/update-build-version.js",
    "pw-tests-dev-ru": "TEST_ENV=dev-ru playwright test",
    "pw-tests-ru": "TEST_ENV=ru playwright test",
    "pw-tests-ui-dev-ru": "TEST_ENV=dev-ru playwright test --ui",
    "pw-tests-ui-ru": "TEST_ENV=ru playwright test --ui",
    "format": "prettier --write \"./**/*.{ts,js,scss}\"",
    "lint": "eslint . --ext .ts,.html",
    "jest": "jest",
    "api-tests": "jest tests/api"
  },
  "private": true,
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/platform-server": "^22.0.1",
    "@angular/pwa": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "@auth0/auth0-angular": "^2.2.3",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@sentry/angular": "^10.57.0",
    "assertic": "^1.3.0",
    "aws-jwt-verify": "^4.0.1",
    "body-parser": "^2.2.0",
    "core-js": "^3.43.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "frescas": "^0.9.0",
    "hammerjs": "^2.0.8",
    "jwks-rsa": "^3.2.0",
    "mysql2": "^3.14.1",
    "nanoid": "^3.3.11",
    "node-telegram-bot-api": "^0.66.0",
    "nosleep.js": "^0.12.0",
    "otrie": "^1.2.1",
    "pure-md5": "0.1.14",
    "rxjs": "^7.8.2",
    "schema-dts": "^1.1.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.1",
    "@angular/build": "^22.0.1",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/language-service": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@sentry/cli": "^2.46.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "4.17.21",
    "@types/hammerjs": "^2.0.46",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.1",
    "@types/node-telegram-bot-api": "^0.64.9",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@ungap/structured-clone": "^1.3.0",
    "angular-eslint": "^22.0.0",
    "browser-sync": "^3.0.4",
    "eslint": "^10.5.0",
    "fake-indexeddb": "^6.0.1",
    "http-server": "^14.1.1",
    "istanbul-lib-instrument": "^6.0.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
