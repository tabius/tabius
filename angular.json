{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "tabius": {
      "root": "",
      "sourceRoot": "app",
      "projectType": "application",
      "prefix": "gt",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist"
            },
            "index": "app/index.html",
            "polyfills": ["app/polyfills.ts"],
            "tsConfig": "tsconfig.app.json",
            "allowedCommonJsDependencies": ["assertic", "hammerjs", "nosleep.js", "pure-md5"],
            "assets": [
              {
                "glob": "**/*",
                "input": "app/assets",
                "output": "/assets"
              },
              {
                "glob": "favicon.*",
                "input": "app",
                "output": "/"
              },
              "app/manifest.json"
            ],
            "styles": ["app/styles.scss", "node_modules/@angular/cdk/overlay-prebuilt.css"],
            "stylePreprocessorOptions": {
              "includePaths": ["app"]
            },
            "scripts": [],
            "sourceMap": true,
            "browser": "app/main.ts",
            "server": "app/main.server.ts",
            "security": {
              "allowedHosts": ["localhost", "127.0.0.1", "tabius.ru", "tabius.org"]
            },
            "outputMode": "server",
            "ssr": {
              "entry": "app/server.ts"
            }
          },
          "configurations": {
            "ru": {
              "fileReplacements": [
                {
                  "replace": "app/environments/environment.ts",
                  "with": "app/environments/environment.prod-ru.ts"
                }
              ],
              "aot": true,
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json"
            },
            "org": {
              "index": "app/index-org.html",
              "fileReplacements": [
                {
                  "replace": "app/environments/environment.ts",
                  "with": "app/environments/environment.prod-org.ts"
                }
              ],
              "aot": true,
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json"
            },
            "dev-ru": {
              "aot": false,
              "optimization": false
            },
            "dev-ru-csr": {
              "aot": false,
              "optimization": false,
              "ssr": false,
              "server": false,
              "outputMode": "static"
            },
            "dev-org": {
              "aot": false,
              "optimization": false,
              "index": "app/index-org.html",
              "fileReplacements": [
                {
                  "replace": "app/environments/environment.ts",
                  "with": "app/environments/environment.dev-org.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "dev-ru"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "tabius:build",
            "port": 12101
          },
          "configurations": {
            "ru": {
              "buildTarget": "tabius:build:ru"
            },
            "org": {
              "buildTarget": "tabius:build:org"
            },
            "dev-ru": {
              "buildTarget": "tabius:build:dev-ru"
            },
            "dev-ru-csr": {
              "buildTarget": "tabius:build:dev-ru-csr"
            },
            "dev-org": {
              "buildTarget": "tabius:build:dev-org"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "app/test.ts",
            "polyfills": "app/polyfills.ts",
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "app/karma.conf.js",
            "scripts": []
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "e2e/protractor.conf.js",
            "devServerTarget": "tabius:serve"
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "changeDetection": "OnPush",
      "inlineStyle": false,
      "inlineTemplate": false,
      "module": "app",
      "prefix": "gt",
      "skipTests": true,
      "style": "scss"
    },
    "@schematics/angular:directive": {
      "prefix": "gt",
      "module": "app"
    },
    "@schematics/angular:module": {
      "spec": false
    }
  },
  "cli": {
    "analytics": false
  }
}
